# ============================================================
# 运行模式
# ============================================================
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173

# ============================================================
# AI 模型（Hackathon 阶段 — BYOK，用户运行时通过 X-API-Key 传入）
# ============================================================
MODEL_PROVIDER=claude

# ============================================================
# Supabase
# ============================================================
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ============================================================
# L3 预制 Plug（平台持有，后端代理）
# ============================================================
# Unsplash — https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Mapbox — https://account.mapbox.com/
MAPBOX_ACCESS_TOKEN=your_mapbox_access_token_here

# ============================================================
# L4 魔法连接（平台持有，后端代理）
# ============================================================
# 高德地图天气 — https://lbs.amap.com/
AMAP_KEY=your_amap_key_here

# 百度翻译 — https://fanyi-api.baidu.com/
BAIDU_TRANSLATE_APPID=your_baidu_appid_here
BAIDU_TRANSLATE_SECRET=your_baidu_secret_here

# 聚合数据新闻 — https://www.juhe.cn/docs/api/id/235
JUHE_NEWS_KEY=your_juhe_key_here
